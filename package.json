{
  "name": "n8n-nodes-hyperledger",
  "version": "1.0.0",
  "description": "n8n community nodes for Hyperledger enterprise blockchain integration - FireFly, Fabric, ACA-Py, and Besu",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "hyperledger",
    "firefly",
    "fabric",
    "aries",
    "aca-py",
    "besu",
    "blockchain",
    "enterprise",
    "distributed-ledger",
    "dlt",
    "web3",
    "verifiable-credentials",
    "decentralized-identity",
    "ssi"
  ],
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA, LLC",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-hyperledger.git"
  },
  "homepage": "https://velobpa.com",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-hyperledger/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FireFlyApi.credentials.js",
      "dist/credentials/FabricGatewayApi.credentials.js",
      "dist/credentials/AcaPyApi.credentials.js",
      "dist/credentials/BesuApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FireFly/FireFly.node.js",
      "dist/nodes/FireFly/FireFlyTrigger.node.js",
      "dist/nodes/Fabric/Fabric.node.js",
      "dist/nodes/Fabric/FabricTrigger.node.js",
      "dist/nodes/AcaPy/AcaPy.node.js",
      "dist/nodes/AcaPy/AcaPyWebhook.node.js",
      "dist/nodes/Besu/Besu.node.js",
      "dist/nodes/Besu/BesuTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.27.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
